# Appwrite (https://appwrite.io). Create a project and copy the values here.
# These are loaded into the browser — Appwrite's project ID is meant to be public.
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your-project-id
VITE_APPWRITE_DATABASE_ID=vault
# Appwrite renamed Collections → Tables. Use the table ID here.
VITE_APPWRITE_TABLE_VAULTS=vaults
